mdl 1.3;

using state import *;

import adobe::mtl::*;
import adobe::util::*;
import ::tex::gamma_mode;
import ::state::normal;

export material wood_mat(*)
  = adobe::mtl::standard(
    opacity : adobe::util::float_texture( texture_2d("boat_STWANZF/wood_mat_opacity.png", ::tex::gamma_linear) ),
    baseColor : adobe::util::color_texture( texture_2d("boat_STWANZF/wood_mat_baseColor.png", ::tex::gamma_srgb) ),
    translucence : float(0.0),
    glow : adobe::util::float_texture( texture_2d("boat_STWANZF/cotton_mat_glow.png", ::tex::gamma_linear) ),
    indexOfRefraction : float(1.5),
    density : float(0.0),
    roughness : adobe::util::float_texture( texture_2d("boat_STWANZF/wood_mat_roughness.png", ::tex::gamma_linear) ),
    normal : adobe::util::normal_texture( texture_2d("boat_STWANZF/wood_mat_normal.png", ::tex::gamma_linear) ),
    interiorColor : color(1.0, 1.0, 1.0),
    metallic : adobe::util::float_texture( texture_2d("boat_STWANZF/wood_mat_metallic.png", ::tex::gamma_linear) ),
    height : float(0.5),
    heightScale : float(1.0)
    );

export material glass_mat(*)
  = adobe::mtl::standard(
    opacity : float(1.0),
    baseColor : adobe::util::color_texture( texture_2d("boat_STWANZF/glass_mat_baseColor.png", ::tex::gamma_srgb) ),
    translucence : float(0.0),
    glow : float(0.0),
    indexOfRefraction : float(1.5),
    density : float(0.0),
    roughness : adobe::util::float_texture( texture_2d("boat_STWANZF/glass_mat_roughness.png", ::tex::gamma_linear) ),
    normal : adobe::util::normal_texture( texture_2d("boat_STWANZF/glass_mat_normal.png", ::tex::gamma_linear) ),
    interiorColor : color(1.0, 1.0, 1.0),
    metallic : adobe::util::float_texture( texture_2d("boat_STWANZF/glass_mat_metallic.png", ::tex::gamma_linear) ),
    height : float(0.5),
    heightScale : float(1.0)
    );

